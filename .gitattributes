# Normalize text files to LF in the repo, regardless of platform checkout.
# Git will convert to CRLF on Windows working copy as needed via core.autocrlf.
* text=auto eol=lf

# Binary files must never be diffed/merged as text.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.exe binary
*.dll binary
*.pdb binary
*.zip binary
*.gz binary
